      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"deleted_totps\" (\"uuid\" TEXT NOT NULL, PRIMARY KEY (\"uuid\"));"
        }
      ]
    },
    {
      "name": "pending_backend_push_operations",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"pending_backend_push_operations\" (\"uuid\" TEXT NOT NULL, \"kind\" TEXT NOT NULL, \"json_payload\" TEXT NOT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), PRIMARY KEY (\"uuid\"));"
        }
      ]
    },
    {
      "name": "backend_push_operation_errors",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"backend_push_operation_errors\" (\"operation_uuid\" TEXT NOT NULL, \"totp_uuid\" TEXT NOT NULL, \"error_kind\" TEXT NOT NULL, \"error_details\" TEXT NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
