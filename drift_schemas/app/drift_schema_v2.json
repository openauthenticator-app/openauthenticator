      "name": "totps",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"totps\" (\"uuid\" TEXT NOT NULL, \"secret\" TEXT NOT NULL, \"label\" TEXT NULL, \"issuer\" TEXT NULL, \"algorithm\" TEXT NULL, \"digits\" INTEGER NULL, \"validity\" INTEGER NULL, \"image_url\" TEXT NULL, \"encryption_salt\" TEXT NOT NULL, \"updated_at\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"uuid\"));"
        }
      ]
    },
    {
